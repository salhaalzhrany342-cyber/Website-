<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><title>AI CHACHA</title><meta name="viewport" content="width=device-width, initial-scale=1.0"><!-- Fonts --><link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet"><style>body {  margin: 0;  font-family: 'Poppins', sans-serif;  background: radial-gradient(circle at top, #0a0a0a, #000);  color: white;  overflow-x: hidden;}/* PARTICLE BACKGROUND */canvas {  position: fixed;  top: 0;  left: 0;  z-index: -1;}/* NAV */.nav {  display: flex;  justify-content: space-between;  padding: 20px 40px;  position: fixed;  width: 100%;  background: rgba(0,0,0,0.6);  backdrop-filter: blur(10px);}.logo {  font-weight: 700;  color: #00ffcc;}/* HERO */.hero {  text-align: center;  padding: 180px 20px;}.hero h1 {  font-size: 70px;  background: linear-gradient(90deg, #00ffcc, #00aaff);  -webkit-background-clip: text;  -webkit-text-fill-color: transparent;  animation: glow 2s infinite alternate;}@keyframes glow {  from { text-shadow: 0 0 10px #00ffcc; }  to { text-shadow: 0 0 25px #00aaff; }}.hero p {  color: #aaa;  margin-top: 20px;}/* CARD */.card {  max-width: 700px;  margin: 60px auto;  padding: 30px;  border-radius: 20px;  background: rgba(255,255,255,0.05);  backdrop-filter: blur(15px);  border: 1px solid rgba(255,255,255,0.1);  transition: 0.4s;}.card:hover {  transform: scale(1.03);}/* SECTION */.section {  padding: 100px 20px;  text-align: center;}/* FOOTER */footer {  text-align: center;  padding: 40px;  color: #666;}</style></head><body><!-- PARTICLES --><canvas id="bg"></canvas><!-- NAV --><div class="nav">  <div class="logo">AI CHACHA</div></div><!-- HERO --><div class="hero">  <h1>The Smartest Wrong AI</h1>  <p>Where intelligence meets chaos.</p></div><!-- ABOUT --><div class="section">  <div class="card">    AI CHACHA explores the unpredictable nature of intelligence,    combining AI concepts with real-world randomness.  </div></div><!-- VISION --><div class="section">  <div class="card">    Not about perfect prediction — but understanding uncertainty    in a digital world driven by emotion and data.  </div></div><!-- FOOTER --><footer>  © 2026 AI CHACHA — Ultra Premium Experience</footer><script>/* PARTICLE SYSTEM */const canvas = document.getElementById("bg");const ctx = canvas.getContext("2d");canvas.width = window.innerWidth;canvas.height = window.innerHeight;let particles = [];for(let i=0;i<80;i++){  particles.push({    x: Math.random()*canvas.width,    y: Math.random()*canvas.height,    size: Math.random()*2,    speed: Math.random()*0.5  });}function animate(){  ctx.clearRect(0,0,canvas.width,canvas.height);  particles.forEach(p=>{    p.y -= p.speed;    if(p.y < 0) p.y = canvas.height;    ctx.fillStyle = "#00ffcc";    ctx.beginPath();    ctx.arc(p.x,p.y,p.size,0,Math.PI*2);    ctx.fill();  });  requestAnimationFrame(animate);}animate();</script></body></html><!-- COMMUNITY --><div class="section fade" id="community">  <h2>Community</h2>  <div class="card">    Join discussions and explore ideas with a growing network.    <br><br>    <a href="#" style="color:#00ffcc;">https://x.com/AIButChacha</a> |    <a href="#" style="color:#00ffcc;">https://t.me/TrustChacha</a>
